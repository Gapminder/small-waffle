{
  "name": "small-waffle",
  "version": "2.5.2",
  "description": "Lightweight Waffle Server.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start:api": "PORT=4444 VERBOSITY=4 nodemon index.js --ignore datasets/ --ignore events/ --ignore backup/",
    "start:sidecar": "SIDECAR_PORT=4445 VERBOSITY=4 nodemon git-ops-sidecar-process.index.js --watch git-ops-sidecar-process.index.js",
    "start": "concurrently -k -n API,GITOPS -c green,cyan \"npm:start:api\" \"npm:start:sidecar\"",
    "serve": "pm2 start pm2.config.cjs",
    "test": "export PORT=4444 && export VERBOSITY=0 && export EVENTFILENAME=test && export NODE_ENV=test && mocha --timeout 2000 --exit",
    "build": "echo 'There is no build, use `npm start` on dev, `npm test` to test, `npm run serve` in prod'"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@gapminder/validate-ddf": "2.4.1",
    "@koa/cors": "^5.0.0",
    "@octokit/auth-app": "^8.2.0",
    "@vizabi/reader-ddfcsv": "4.6.1",
    "crypto": "^1.0.1",
    "csv-parser": "^3.2.1",
    "dotenv": "^17.4.2",
    "isomorphic-git": "^1.37.6",
    "koa": "^3.2.0",
    "koa-compress": "^5.2.1",
    "koa-jwt": "^4.0.4",
    "koa-router": "^14.0.0",
    "koa-static": "^5.0.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "urlon": "^2.1.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
